# Refuse to install under a Node or pnpm version the workspace does not support,
# rather than failing later with a confusing type or syntax error.
engine-strict=true

# Fail the install when a dependency's peer requirement is unmet instead of
# leaving a subtly broken tree to be discovered at runtime.
strict-peer-dependencies=true

# Workspace packages resolve to the local source only when the dependency uses
# the workspace: protocol. An explicit `workspace:*` is a decision; an implicit
# link is an accident waiting to differ from what CI installs.
link-workspace-packages=false
