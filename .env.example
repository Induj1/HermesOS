# HermesOS environment template.
#
# Copy to .env and fill in real values:  just env-init
# (env-init also replaces every CHANGE_ME below with a generated secret.)
#
# .env is git-ignored and must never be committed. Add new variables here — with
# a safe placeholder, never a real secret — whenever you add one to the code.

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------

NODE_ENV=development
LOG_LEVEL=debug

# Local development runs against native services (Homebrew on macOS); the
# Docker definitions in docker-compose.yml are opt-in behind the `containerized`
# profile. Variables below are marked [both] or [containerized] accordingly.

# ---------------------------------------------------------------------------
# API service (@hermes/api)
# ---------------------------------------------------------------------------

# [both] TCP port the HTTP API listens on.
PORT=3000
# [both] Interface to bind. 0.0.0.0 so a container's published port is
# reachable; set 127.0.0.1 to restrict the process to loopback on a bare host.
HOST=0.0.0.0
# [both] Name stamped on every structured log line.
SERVICE_NAME=hermes-api

# ---------------------------------------------------------------------------
# Telegram bot (@hermes/telegram-app)
# ---------------------------------------------------------------------------

# A task-executing agent you talk to from your phone. Get a token from @BotFather
# (Telegram → /newbot), then run:  pnpm --filter @hermes/telegram-app dev
#
# [both] The BotFather token. Required — the bot will not start without it.
TELEGRAM_BOT_TOKEN=CHANGE_ME
# [both] Ollama's OpenAI-compatible endpoint. Note the /v1 suffix.
OLLAMA_BASE_URL=http://localhost:11434/v1
# [both] The chat model the agent reasons with. A 0.5b model connects but is too
# small to use tools reliably — pull a 7b+ model (`ollama pull qwen2.5:7b`) for
# real task execution.
OLLAMA_MODEL=qwen2.5:0.5b
# [both] Directory the agent's file tools are confined to (created on start).
WORKSPACE_DIR=./hermes-workspace
# [both] Give the agent an allowlisted shell tool. Off by default — running
# commands from a chat message is powerful (node/npm can run arbitrary code)
# and worth an explicit opt-in. Turn on to let the agent scaffold and build.
ENABLE_SHELL=false
# [both] Programs the shell tool may run when ENABLE_SHELL=true. Comma-separated,
# matched on program name only. Default is a developer set (no rm/sudo).
SHELL_ALLOWLIST=ls,cat,echo,pwd,date,head,tail,wc,grep,find,mkdir,touch,cp,which,sed,node,npm,npx,pnpm,yarn,git,tsc
# [both] Timeout and output cap for one shell command (installs/builds are slow
# and verbose).
SHELL_TIMEOUT_MS=180000
SHELL_MAX_OUTPUT_BYTES=4000000
# [both] Give the agent a python.run tool (pandas/numpy/matplotlib data analysis
# and charts). Off by default — like the shell it runs arbitrary code, so it is
# an explicit opt-in. Reuses IMAGEGEN_PYTHON as the interpreter (a venv with
# pandas + matplotlib installed). Charts are written into WORKSPACE_DIR so you
# can pull them back with /get.
ENABLE_PYTHON=false
IMAGEGEN_PYTHON=
# [both] OCR: photograph a doc/receipt with the caption "read this" and get the
# text back; also gives the agent an image.ocr tool. Needs Tesseract on PATH
# (`brew install tesseract`).
ENABLE_OCR=false
TESSERACT_BIN=tesseract
# [both] Background removal: send a photo captioned "remove background" for a
# transparent PNG cutout. Path to the rembg script; runs via IMAGEGEN_PYTHON
# (`pip install "rembg[cpu]"`). Empty disables it.
REMBG_SCRIPT=
# [both] Translation: a text.translate tool and a /translate <language> <text>
# command, powered by the local model — no extra dependency, so on by default.
ENABLE_TRANSLATE=true
# [both] Diagrams: a diagram.render tool that turns Mermaid source into a PNG
# (ask "draw a flowchart of X"). Renders via ENABLE_BROWSER's Chromium and a
# vendored mermaid.js. MERMAID_ASSET points at that bundle.
ENABLE_DIAGRAM=false
MERMAID_ASSET=apps/telegram/assets/mermaid.min.js
# [both] QR codes: /qr <text or url> generates one; a photo captioned "scan qr"
# is decoded. Scripts run via IMAGEGEN_PYTHON (`pip install "qrcode[pil]"
# "opencv-python-headless<5"`). Empty disables that direction.
QR_MAKE_SCRIPT=
QR_READ_SCRIPT=
# [both] Photo studio: a photo captioned "blur faces" / "meme: top | bottom" /
# "sticker" runs the matching script via IMAGEGEN_PYTHON. Face blur uses OpenCV
# (needs "opencv-python-headless<5" for the Haar cascade); sticker reuses rembg;
# meme uses Pillow. Empty disables that one.
BLUR_FACES_SCRIPT=
MEME_SCRIPT=
STICKER_SCRIPT=
# [both] Heavy AI media (torch venv). A photo captioned "upscale"/"enhance" runs
# a 4x super-resolution (SD x4 upscaler); "erase the <object>" runs text-guided
# inpainting (CLIPSeg mask + SD inpainting); an audio file captioned
# "instrumental"/"vocals only" is split with Demucs (`pip install demucs`).
# Models download on first use. Empty disables that one.
UPSCALE_SCRIPT=
INPAINT_SCRIPT=
STEM_SCRIPT=
# [both] Audiobook: /audiobook <path> narrates a workspace .md/.txt/.pdf to an
# MP3. Uses the same TTS as voice replies (Piper or say) plus ffmpeg and, for
# PDFs, pdftotext (poppler).
ENABLE_AUDIOBOOK=false
AUDIOBOOK_MAX_CHARS=20000
# [both] Short video: /video <prompt> makes an animated clip (sd-turbo latent
# walk → MP4). Runs via IMAGEGEN_PYTHON (torch + diffusers + `pip install imageio
# imageio-ffmpeg`). Empty disables it.
VIDEO_SCRIPT=
# [both] Repo Q&A: /repo <path> indexes a local source repo into the embedding
# store so you can ask questions across the whole codebase.
ENABLE_REPO_QA=false
# [both] Career toolkit: /coverletter <JD>, /tailor <JD>, /interview <role> —
# résumé-grounded job helpers. Best paired with OWNER_PROFILE and an ingested
# résumé (drop it in DOCS_DIR and /ingest).
ENABLE_CAREER=false
# [both] Application tracker: /apply <Company> | <Role>, /applications, /status —
# logs job applications and schedules a follow-up reminder.
ENABLE_APPLICATIONS=false
APPLICATION_FOLLOWUP_DAYS=7
# [both] Security tools: /scan <url> (header audit), /cve <keyword> (NVD lookup),
# and /encode /decode /hash. Also gives the agent a security.cve tool.
ENABLE_SECURITY=false
# [both] Code review: /review <code|path> runs a security-aware review via the agent.
ENABLE_REVIEW=false
# [both] Research radar: /arxiv <topic> and a research.arxiv agent tool — pair with
# /every for a recurring paper digest.
ENABLE_RESEARCH=false
# [both] Recurring agent tasks: /every <schedule> <task> runs the agent on a cron
# and messages you the result (e.g. "/every weekdays 9am summarise new issues").
# Manage with /schedules and /unschedule. Times are local and converted to UTC.
ENABLE_SCHEDULES=false
# [both] Structured extraction: a photo captioned "receipt"/"extract"/"to json"
# is OCR'd and the model returns clean JSON. Needs ENABLE_OCR.
ENABLE_EXTRACT=false
# [both] Music video: /musicvideo <prompt> makes a clip (VIDEO_SCRIPT) with a
# generated soundtrack (MUSIC_SCRIPT) muxed in. Needs both scripts.
ENABLE_MUSIC_VIDEO=false
# [both] Max reasoning turns (model call + tools) per incoming message.
MAX_TURNS=12
# [both] Team of specialist agents (researcher/coder/planner) behind a router.
ENABLE_TEAM=true
# [both] Memory + "chat with my files" (RAG): a local embedding store.
EMBEDDING_MODEL=all-minilm
DATA_DIR=./hermes-data
DOCS_DIR=./hermes-docs
MEMORY_RECALL=5
# [both] Image input: an Ollama vision model (empty = off). Needs `ollama pull llava:7b`.
VISION_MODEL=llava:7b
# [both] Voice notes: a whisper.cpp model path (empty = off). Needs whisper-cli +
# ffmpeg on PATH (`brew install whisper-cpp ffmpeg`) and a downloaded ggml model.
WHISPER_MODEL=
WHISPER_CLI=whisper-cli
# [both] Morning briefing (weather + Hacker News) and a CI-failure watcher.
ENABLE_BRIEFING=true
BRIEFING_CITY=Bengaluru
BRIEFING_LAT=12.97
BRIEFING_LON=77.59
# Cron is 5-field UTC. 30 2 * * * = 08:00 IST. Unset BRIEFING_CHAT_ID to reach
# every chat that has messaged the bot.
BRIEFING_CRON=30 2 * * *
# BRIEFING_CHAT_ID=123456789
# Watch CI for this repo (empty = off); DMs on a failing GitHub Actions run.
CI_REPO=
CI_BRANCH=main
CI_CRON=0 18 * * *

# ---------------------------------------------------------------------------
# Networking
# ---------------------------------------------------------------------------

# [containerized] Interface the Docker port mappings bind to. Keep 127.0.0.1
# unless you deliberately want these services reachable from other machines.
HOST_BIND=127.0.0.1

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------

# [containerized] Image tag. The native version is whatever brew installed.
POSTGRES_VERSION=17-alpine

# [both] `just db-init` provisions this role and database in the native cluster
# using this password, so the connection string is identical either way.
POSTGRES_USER=hermes
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=hermes
POSTGRES_PORT=5432

# [both] Connection string used by the app. Keep the credentials above in sync.
DATABASE_URL=postgresql://hermes:CHANGE_ME@127.0.0.1:5432/hermes

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------

# [containerized] Image tag. The native version is whatever brew installed.
REDIS_VERSION=7.4-alpine

# [containerized] A stock Homebrew Redis has no requirepass, and setting one
# would affect every other project on this machine — so local dev runs
# unauthenticated on 127.0.0.1 and REDIS_URL below carries no credentials.
# The containerized profile refuses to start without this set: fill it in AND
# add it back to REDIS_URL when opting in, naming the `default` user:
#
#   REDIS_URL=redis://default:<password>@127.0.0.1:6379
#
# Spell out `default` rather than the shorter redis://:<password>@ form —
# redis-cli 8 reads the empty username literally and sends AUTH "" <password>,
# which the server rejects with WRONGPASS.
REDIS_PASSWORD=

# [both]
REDIS_PORT=6379

# [containerized]
REDIS_MAXMEMORY=512mb
# noeviction is correct when Redis holds queues or sessions — it errors on a full
# heap instead of silently dropping data. Use allkeys-lru for a pure cache.
REDIS_MAXMEMORY_POLICY=noeviction

# [both] No password: see REDIS_PASSWORD above.
REDIS_URL=redis://127.0.0.1:6379

# ---------------------------------------------------------------------------
# Ollama
# ---------------------------------------------------------------------------

# [containerized] Pin to a specific release (e.g. 0.6.2) once you have a version
# you trust — `latest` will drift under you and is not reproducible.
OLLAMA_VERSION=latest

# [both]
OLLAMA_PORT=11434
OLLAMA_URL=http://127.0.0.1:11434

# [both] Models `just ollama-pull` fetches during setup. Comma-separated.
OLLAMA_MODELS=llama3.2,nomic-embed-text

# [containerized] The native Homebrew Ollama reads its own config, not .env —
# set these for the native server with `launchctl setenv` or by editing the
# service plist. They are passed to the container as-is.
#
# How long a model stays resident in memory after its last request.
OLLAMA_KEEP_ALIVE=5m
# Raise only if you have the VRAM/RAM headroom for concurrent models.
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_NUM_PARALLEL=1
# Used by the `gpu` compose profile: a count, or `all`.
OLLAMA_GPU_COUNT=all
