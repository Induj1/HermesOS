# ---------------------------------------------------------------------------
# Secrets and local config
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
# Anchored to the repo root so it ignores a local ./secrets/ of real secret
# files without also swallowing the packages/secrets source package.
/secrets/

# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
node_modules/
.pnpm-store/
.pnpm-debug.log*
.yarn/
.npm/

# ---------------------------------------------------------------------------
# Build output
# ---------------------------------------------------------------------------
dist/
build/
out/
*.tsbuildinfo
.next/
.nuxt/
.svelte-kit/
.astro/

# ---------------------------------------------------------------------------
# Caches
# ---------------------------------------------------------------------------
.turbo/
.cache/
.eslintcache
.parcel-cache/
.vite/
.rollup.cache/
.swc/

# ---------------------------------------------------------------------------
# Tests and coverage
# ---------------------------------------------------------------------------
coverage/
.nyc_output/
test-results/
playwright-report/
blob-report/
.playwright/

# ---------------------------------------------------------------------------
# Logs and runtime
# ---------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-error.log*
pids/
*.pid
*.seed

# ---------------------------------------------------------------------------
# Local data — Docker keeps state in named volumes, but these appear if a
# service is ever run natively or a bind mount is added.
# ---------------------------------------------------------------------------
data/
backups/
tmp/
.ollama/

# ---------------------------------------------------------------------------
# Editors
# ---------------------------------------------------------------------------
.idea/
*.iml
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
*.swp
*.swo

# Claude Code local settings — may hold secrets (e.g. bot tokens) and
# machine-specific permission rules. Never commit.
.claude/settings.local.json

# The Telegram agent's runtime workspace — files the bot writes at runtime.
hermes-workspace/

# The Telegram agent's persistent data (memory store).
hermes-data/

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
.DS_Store
.AppleDouble
Thumbs.db
desktop.ini

# The Telegram agent's ingest docs folder.
hermes-docs/

# Stable Diffusion python venv (torch + diffusers) for /imagine.
.venv-sd/
